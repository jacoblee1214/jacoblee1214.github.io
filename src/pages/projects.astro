---
import BaseLayout from "../layouts/BaseLayout.astro";
import HorizontalCard from "../components/HorizontalCard.astro";
---

<BaseLayout title="Projects" sideBarActiveItemID="projects">
  <div>
    <div class="text-3xl w-full font-bold mb-2">Projects</div>
    <p class="mb-6 opacity-80">
      A decade of deploying AI on physical systems — from factory floors in Korea, to solar micro-grids in rural Tanzania, to current work on humanoid robotics.
    </p>
  </div>

  <HorizontalCard
    title="Broken Stitch Detection System"
    subtitle="Industrial sewing machines — HSV color space + image processing"
    img="/images/projects/stitch.svg"
    desc="A real-time defect detection system deployed on industrial sewing machines in Korean garment factories. Uses HSV color space analysis and image processing to catch broken stitches before they compound into larger defects. Published in Journal of Computational Design and Engineering (IF 6.167)."
    url="#"
    target="_self"
    badge="Published"
    tags={["Computer Vision", "Industrial Deployment", "Patent"]}
  />
  <div class="divider my-0"></div>

  <HorizontalCard
    title="FDM 3D Printing Anomaly Detection"
    subtitle="Vision-based failure detection for material extrusion"
    img="/images/projects/fdm.svg"
    desc="A systematic deep transfer learning method for detecting spaghetti-shape defects in fused deposition modeling. Solves the small-dataset problem common in real factory deployments. Co-first author, published in Journal of Manufacturing Systems (IF 12.1)."
    url="#"
    target="_self"
    badge="Published"
    tags={["Transfer Learning", "Anomaly Detection"]}
  />
  <div class="divider my-0"></div>

  <HorizontalCard
    title="Sound-Based Multi-Device Monitoring"
    subtitle="CNN-based acoustic monitoring for manufacturing equipment"
    img="/images/projects/sound.svg"
    desc="A remote real-time operational monitoring system that uses only microphones and CNNs to track the status of multiple manufacturing devices simultaneously. Published in Journal of Manufacturing Systems — top 6% in Operations Research & Management Science. Korean patent registered."
    url="#"
    target="_self"
    badge="Published"
    tags={["Acoustic AI", "Edge Deployment", "Patent"]}
  />
  <div class="divider my-0"></div>

  <HorizontalCard
    title="Appropriate Smart Factory for SMEs"
    subtitle="Concept, application, and perspective for small-scale manufacturers"
    img="/images/projects/smartfactory.svg"
    desc="A framework paper on how to build smart factories that actually fit small- and medium-sized manufacturers — not scaled-down versions of enterprise systems. Most Downloaded Article Award (IJPEM, 2020–2021)."
    url="#"
    target="_self"
    badge="Award"
    tags={["Framework", "Smart Manufacturing"]}
  />
  <div class="divider my-0"></div>

  <HorizontalCard
    title="Edge AI + Solar Micro-grid in Rural Tanzania"
    subtitle="4-year deployment — Ph.D. thesis"
    img="/images/projects/tanzania.svg"
    desc="A mobile energy management system integrating tiny ML, IoT, and solar micro-grids to power electric motorcycles in rural Tanzania. Led the AI and IoT portions of a $2.24M NRF project. Tested in real deployment conditions in Arusha over four years. The single most formative experience in my career — taught me everything I know about what 'deployment' actually means."
    url="#"
    target="_self"
    badge="Ph.D. Thesis"
    tags={["Edge AI", "IoT", "Field Deployment"]}
  />
  <div class="divider my-0"></div>

  <HorizontalCard
    title="VLM/LLM Study & Implementation"
    subtitle="Personal experiments building with vision-language models and agents"
    img="/images/projects/vlm.svg"
    desc="Ongoing personal project exploring VLM/LLM architectures, agent designs, and Claude skills customization. Building a personal assistant ('Jarvis') from scratch to understand the building blocks of embodied agents from the inside. Code and experiments on GitHub."
    url="https://github.com/jacoblee1214"
    badge="Side Project"
    tags={["LLM", "Agents", "VLM"]}
  />
</BaseLayout>
