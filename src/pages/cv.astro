---
import BaseLayout from "../layouts/BaseLayout.astro";
import TimeLineElement from "../components/cv/TimeLine.astro";
---

<BaseLayout title="CV" sideBarActiveItemID="cv">
  <div class="mb-8">
    <div class="text-4xl w-full font-bold">Hyunsu Lee, Ph.D.</div>
    <div class="text-lg opacity-80 mt-1">Physical AI Systems Engineer · Seoul, Korea</div>
    <div class="mt-3">
      <a class="btn btn-sm btn-outline" href="/cv.pdf" target="_blank">Download full CV (PDF)</a>
    </div>
  </div>

  <div class="mb-5">
    <div class="text-3xl w-full font-bold">Education</div>
  </div>

  <div class="time-line-container grid gap-4 mb-10">
    <TimeLineElement
      title="Ph.D., Mechanical Engineering — Seoul National University"
      subtitle="2018–2024 · Advisor: Prof. Sung-Hoon Ahn"
    >
      Thesis: <i>Energy availability system for electric motorcycle with micro-off-grid system in Tanzanian rural area.</i>
    </TimeLineElement>
    <TimeLineElement
      title="M.S., Electrical and Electronics Engineering — Chung-Ang University"
      subtitle="2016–2018 · Advisor: Prof. Hoon Kang"
    >
      Thesis: <i>A Structure of Convolutional Neural Networks for Image Contents Search.</i>
    </TimeLineElement>
    <TimeLineElement
      title="B.S., Electrical and Electronics Engineering — Chung-Ang University"
      subtitle="2011–2015"
    />
  </div>

  <div class="mb-5">
    <div class="text-3xl w-full font-bold">Experience</div>
  </div>

  <div class="time-line-container mb-10">
    <TimeLineElement
      title="AI Researcher, Robotics"
      subtitle="2026–present"
    >
      Humanoid robotics — vision-language-action (VLA) models and dexterous manipulation.
    </TimeLineElement>
    <TimeLineElement
      title="Visiting Postdoctoral Researcher — University of Connecticut"
      subtitle="2024–2025"
    />
    <TimeLineElement
      title="Postdoctoral Researcher — Seoul National University"
      subtitle="2024–2025"
    />
    <TimeLineElement
      title="Graduate Research Assistant — Seoul National University"
      subtitle="2018–2024"
    >
      Smart manufacturing, edge AI, IoT systems, and the Tanzania solar micro-grid deployment.
    </TimeLineElement>
    <TimeLineElement
      title="Graduate Research Assistant — Chung-Ang University"
      subtitle="2016–2018"
    >
      Deep learning for image recognition and content-based retrieval.
    </TimeLineElement>
  </div>

  <div class="mb-5">
    <div class="text-3xl w-full font-bold">Selected Publications</div>
  </div>

  <ol class="list-decimal mx-6 mb-4 grid gap-2">
    <li>
      Lee, H.S. et al. (2026). <i>Inclusive AI and Low-Cost Robotics for Sustainable Smart Systems.</i> IJPEM-Smart Technology.
    </li>
    <li>
      Lee, H.S. et al. (2025). <i>Mobile Energy Management System for E-Motorcycle Integrated with Micro Off-Grid.</i> IJPEM-Green Technology.
    </li>
    <li>
      Kim, H.J., Lee, H.S., Ahn, S.H. (2022). <i>Systematic deep transfer learning for FDM spaghetti-shape defect monitoring.</i> Journal of Manufacturing Systems, IF 12.1.
    </li>
    <li>
      Kim, J.S., Lee, H.S. et al. (2021). <i>Sound-based remote real-time monitoring using CNN.</i> Journal of Manufacturing Systems. Top 6% in OR&amp;MS.
    </li>
    <li>
      Jung, W.K., Kim, D.R., Lee, H.S. et al. (2021). <i>Appropriate smart factory for SMEs.</i> IJPEM. Most Downloaded Article Award.
    </li>
  </ol>
  <p class="mb-10">
    Full list: <a class="link link-primary" href="https://scholar.google.co.kr/citations?user=Bmx1DpMAAAAJ&hl=ko" target="_blank">Google Scholar</a> <span class="opacity-60">(placeholder link)</span>
  </p>

  <div class="mb-5">
    <div class="text-3xl w-full font-bold">Patents</div>
  </div>

  <ul class="list-disc mx-6 mb-10 grid gap-2">
    <li>"Method of automatically detecting sewing stitching defect" — SNU, 2023</li>
    <li>"Sound-based multi-device operation monitoring method" — SNU, 2023</li>
    <li>"Sewing stitching defect method and system" — SNU, 2021</li>
  </ul>

  <div class="mb-5">
    <div class="text-3xl w-full font-bold">Skills</div>
  </div>

  <ul class="list-disc mx-6 mb-10 grid gap-2">
    <li><b>Languages:</b> Python, C, C++, MATLAB, SQL</li>
    <li><b>ML/AI Frameworks:</b> PyTorch, TensorFlow, Hugging Face Transformers, OpenCV</li>
    <li><b>Foundation Models:</b> LLM/VLM fine-tuning, RLHF, prompt engineering, multimodal training, agent frameworks (Claude Code, Claude Skills)</li>
    <li><b>Robotics & Embodied AI:</b> Vision-language-action models, dexterous manipulation, sim-to-real, multimodal perception</li>
    <li><b>Systems:</b> Data pipelines, model deployment, edge ML, anomaly detection</li>
    <li><b>Hardware:</b> PCB design, 3D printing, collaborative robots, CNC, IoT/edge devices</li>
  </ul>

  <div class="mb-5">
    <div class="text-3xl w-full font-bold">Select Awards</div>
  </div>

  <ul class="list-disc mx-6 mb-10 grid gap-2">
    <li>Most Downloaded Article Award, IJPEM (2020–2021)</li>
    <li>Best Paper Award, ICAT (2022)</li>
    <li>Best Poster Awards, ICEAS (2023)</li>
  </ul>
</BaseLayout>
